# ─── Database ───────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_NAME=firmware_hub
DB_USER=firmware_user
DB_PASSWORD=changeme_password

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# JWT
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS ────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=your-firmware-bucket

# ─── SES ────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com

# ─── App ────────────────────────────────────────────────────
APP_URL=https://yourdomain.com
INVITE_TOKEN_EXPIRES_HOURS=48
RESET_TOKEN_EXPIRES_HOURS=2

# ─── Frontend (build-time) ──────────────────────────────────
VITE_API_URL=https://yourdomain.com/api
