# ─── Database ───────────────────────────────────────────────
DB_ROOT_PASSWORD=localroot
DB_NAME=firmware_hub
DB_USER=firmware_user
DB_PASSWORD=localpassword
DATABASE_URL=mysql://firmware_user:localpassword@127.0.0.1:3307/firmware_hub

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# JWT  (any 32+ char string works locally)
JWT_ACCESS_SECRET=local_dev_access_secret_min32chars!!
JWT_REFRESH_SECRET=local_dev_refresh_secret_min32chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS  ────────────────────────────────────────────────────
# Replace with real credentials to test S3 upload / SES email flows.
# With placeholder values the app starts fine; only upload/email calls will fail.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIASILY4AXGE4KHYPVQ
AWS_SECRET_ACCESS_KEY=YYUUn9HLfAErb+5S2nGcPnFAtGduaHbQEjUBLGxi
S3_BUCKET_NAME=firmware-hub-biorad

# ─── SES ────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@yourdomain.com

# ─── App ────────────────────────────────────────────────────
APP_URL=http://localhost:5173
INVITE_TOKEN_EXPIRES_HOURS=48
RESET_TOKEN_EXPIRES_HOURS=2

# ─── Frontend (Vite build-time) ──────────────────────────────
VITE_API_URL=http://localhost:4000/api
